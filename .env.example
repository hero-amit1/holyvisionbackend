# ── Server ───────────────────────────────────────────────────
PORT=5001
NODE_ENV=development          # set to "production" on the server

# ── MongoDB ──────────────────────────────────────────────────
# Local:   mongodb://127.0.0.1:27017/holyvision
# Atlas:   mongodb+srv://<user>:<pass>@cluster.mongodb.net/holyvision?retryWrites=true&w=majority
MONGO_URI=mongodb://127.0.0.1:27017/holyvision

# ── Admin credentials ─────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_in_production   # REQUIRED — no default in production

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_string_min_32_chars   # REQUIRED in production
JWT_EXPIRES_IN=8h

# ── Cloudinary (image uploads) ────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Leave blank in development (all origins allowed).
# Example: https://www.holyvisiontechnicalcampus.edu.np,https://holyvisiontechnicalcampus.edu.np
CORS_ALLOWED_ORIGINS=

# ── Upload limits ─────────────────────────────────────────────
UPLOAD_MAX_FILE_SIZE_BYTES=5242880   # 5 MB
